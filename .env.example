# =============================================
# CONFIGURACIÓN GENERAL
# =============================================
APP_NAME="Sistema de Solicitudes - UGC"
APP_ENV=development
BASE_URL=/ugc_incapacidades

# =============================================
# ORACLE (ICEBERG - RH)
# =============================================
ORACLE_HOST=tu_host_oracle_aqui
ORACLE_PORT=1521
ORACLE_USER=tu_usuario_oracle
ORACLE_PASS=tu_contraseña_oracle
ORACLE_SERVICE=tu_service_name
ORACLE_CHARSET=AL32UTF8

# =============================================
# LDAP (Universidad La Gran Colombia)
# =============================================
LDAP_HOST=tu_host_ldap_aqui
LDAP_PORT=389
LDAP_USER=cn=tu_usuario_ldap,ou=users,dc=ejemplo,dc=com
LDAP_PASSWORD=tu_contraseña_ldap
LDAP_TREE=ou=users,dc=ejemplo,dc=com
